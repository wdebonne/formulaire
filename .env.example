# Environment variables
DATABASE_URL="file:./dev.db"

# JWT Secret — OBLIGATOIRE, minimum 32 caractères.
# Générer avec : openssl rand -base64 32
JWT_SECRET=""

# IPs des reverse proxies de confiance (nginx/traefik/etc.) — séparées par des virgules.
# Quand défini, X-Forwarded-For n'est utilisé que si la connexion vient d'une de ces IPs.
# Exemple Docker : TRUSTED_PROXY_IPS="172.17.0.1"
# Laisser vide si l'app est exposée directement (pas de reverse proxy).
TRUSTED_PROXY_IPS=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email configuration (for password reset)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-password"
SMTP_FROM="noreply@example.com"
