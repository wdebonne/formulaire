// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Roles: admin, user
model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  name              String?
  role              String   @default("user") // admin, user
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  forms             Form[]
  themes            Theme[]
  sharedForms       FormShare[]
}

model Form {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  status      String   @default("draft") // draft, published
  blocks      String   @default("[]") // JSON string for blocks
  logic       String   @default("{}") // JSON string for logic rules
  settings    String   @default("{}") // JSON string for form settings
  webhooks    String   @default("[]") // JSON string for webhooks config
  themeId     String?
  theme       Theme?   @relation(fields: [themeId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses   Response[]
  shares      FormShare[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}

// Partage de formulaires entre utilisateurs
model FormShare {
  id          String   @id @default(uuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission  String   @default("view") // view, edit
  createdAt   DateTime @default(now())

  @@unique([formId, userId])
  @@index([formId])
  @@index([userId])
}

model Theme {
  id              String   @id @default(uuid())
  name            String
  properties      String   @default("{}") // JSON string for theme properties
  isDefault       Boolean  @default(false)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  forms           Form[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model Response {
  id            String   @id @default(uuid())
  formId        String
  form          Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  data          String   @default("{}") // JSON string for response data
  status        String   @default("completed") // completed, partial
  metadata      String   @default("{}") // JSON for ip, user agent, etc.
  webhookStatus String   @default("{}") // JSON for webhook results {webhookId: {success: boolean, lastSent: date}}
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([formId])
}

// Paramètres système (SMTP, site, etc.)
model SystemSettings {
  id          String   @id @default("system")
  siteName    String   @default("FormBuilder")
  siteLogo    String?  // URL du logo
  siteFavicon String?  // URL du favicon
  smtpHost    String?
  smtpPort    Int      @default(587)
  smtpUser    String?
  smtpPass    String?
  smtpFrom    String?
  smtpFromName String?  // Nom de l'expéditeur
  smtpSecure  Boolean  @default(false)
  registrationEnabled Boolean @default(true)
  updatedAt   DateTime @updatedAt
}

// Templates d'emails
model EmailTemplate {
  id          String   @id @default(uuid())
  name        String   // welcome, forgot-password, form-shared
  slug        String   @unique
  subject     String
  htmlContent String   // HTML template
  variables   String   @default("[]") // JSON array des variables disponibles
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Polices d'écriture personnalisées
model Font {
  id          String   @id @default(uuid())
  name        String   // Nom affiché
  family      String   @unique // Nom CSS de la police (font-family)
  source      String   @default("google") // google, custom
  url         String?  // URL du fichier de police (pour custom)
  weights     String   @default("[400,700]") // JSON array des graisses disponibles
  isDefault   Boolean  @default(false) // Polices par défaut du système
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
